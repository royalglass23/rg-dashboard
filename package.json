{
  "name": "royal-glass-dashboard",
  "version": "2.0.0",
  "description": "Royal Glass Work Order Dashboard — Google Apps Script managed via clasp",
  "scripts": {
    "deploy:staging": "node deploy.js staging",
    "deploy:live": "node deploy.js live",
    "pull:staging": "cp .clasp.staging.json .clasp.json && clasp pull",
    "pull:live": "cp .clasp.live.json .clasp.json && clasp pull"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
